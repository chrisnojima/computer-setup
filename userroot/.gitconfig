[alias] co = checkout
    ec = config --global -e
    up = !git pull --rebase --prune $@ && git submodule update --init --recursive
    squish = "!f() { git rebase -i HEAD~$1; }; f"
    cob = "!f() { git checkout -b nojima/$1; }; f"
    desktop = "!f() { git checkout -b nojima/HOTPOT-$1; }; f"
    cm = !git add -A && git commit -m
    mm = !git fetch && git merge --no-ff origin/master
    save = !git add -A && git commit -m 'SAVEPOINT'
    wip = !git add -u && git commit --no-verify -m "WIP"
    undo = reset HEAD~1 --mixed
    amend = commit -a --amend
    wipe = !git add -A && git commit -qm 'WIPE SAVEPOINT' && git reset HEAD~1 --hard
    bclean = !git bclean1 && git bclean2
    bclean1 = "!f() { git branch --no-color --merged ${1-master} | grep -v " ${1-master}$" | xargs git branch -d; }; f"
    bclean2 = !git branch -vv --no-color | grep ' gone' | cut -d' ' -f1-3 | xargs -n 1 git branch -D
    bdone = "!f() { git checkout ${1-master} && git up && git bclean ${1-master}; }; f"
	tohub = "!f() { BRANCH=\"$(git rev-parse --abbrev-ref HEAD)\"; REPO=\"$(git remote get-url origin | sed -e 's|.*github.com[:/]||' -e 's|\\.git$||')\"; BASE=\"master\"; BEST=999999; for b in $(git for-each-ref --sort=creatordate --format='%(refname:short)' refs/heads/); do [ \"$b\" = \"$BRANCH\" ] && continue; if git merge-base --is-ancestor \"$b\" HEAD 2>/dev/null; then D=$(git rev-list --count \"$b\"..HEAD); if [ \"$D\" -lt \"$BEST\" ] && [ \"$D\" -gt 0 ]; then BEST=$D; BASE=$b; fi; fi; done; echo \"Opening PR: $BRANCH -> $BASE ($REPO)\"; git push --set-upstream origin \"$BRANCH\" && open \"https://github.com/$REPO/compare/$BASE...$BRANCH?expand=1&diff=unified\"; }; f"
    suicide = !git clean -fd && git reset --hard
    hardsuicide = !git clean -fdx && git reset --hard
    migrate = "!f(){ CURRENT=$(git symbolic-ref --short HEAD); git checkout -b $1 && git branch --force $CURRENT ${3-\"$CURRENT@{u}\"} && git rebase --onto ${2-master} $CURRENT; }; f"
    syncfork = !git fetch upstream && git co master && git pull --rebase --all && git push --all origin && git push --tags origin
    forktag = "!f() { git checkout -b packager-allows-mobile-files-0-$1-$2 v0.$1.$2; }; f"
    verify = "!f() { git cat-file -p $1 | head -n 1; }; f"
    cleanonmaster = "!f() { git co master && git desktop $1 && git read-tree $2 && git commit -m 'branch files on master' -n && git reset --hard; }; f"
    recent = "!r() { refbranch=$1 count=$2; git for-each-ref --sort=-committerdate refs/heads --format='%(refname:short)|%(HEAD)%(color:yellow)%(refname:short)|%(color:bold green)%(committerdate:relative)|%(color:blue)%(subject)|%(color:magenta)%(authorname)%(color:reset)' --color=always --count=${count:-20} | while read line; do branch=$(echo \"$line\" | awk 'BEGIN { FS = \"|\" }; { print $1 }' | tr -d '*'); ahead=$(git rev-list --count \"${refbranch:-origin/master}..${branch}\"); behind=$(git rev-list --count \"${branch}..${refbranch:-origin/master}\"); colorline=$(echo \"$line\" | sed 's/^[^|]*|//'); echo \"$ahead|$behind|$colorline\" | awk -F'|' -vOFS='|' '{$5=substr($5,1,70)}1' ; done | ( echo \"ahead|behind||branch|lastcommit|message|author\\n\" && cat) | column -ts'|';}; r"
    recentremote = "!r() { refbranch=$1 count=$2; git for-each-ref --sort=-committerdate refs/remotes/origin --format='%(refname:short)|%(color:yellow)%(refname:short)|%(color:bold green)%(committerdate:relative)|%(color:blue)%(subject)|%(color:magenta)%(authorname)%(color:reset)' --color=always --count=${count:-20} | while read line; do fullbranch=$(echo \"$line\" | awk 'BEGIN { FS = \"|\" }; { print $1 }'); branch=${fullbranch#origin/}; ahead=$(git rev-list --count \"${refbranch:-origin/master}..${fullbranch}\"); behind=$(git rev-list --count \"${fullbranch}..${refbranch:-origin/master}\"); colorline=$(echo \"$line\" | sed 's/^[^|]*|//; s|origin/||'); echo \"$ahead|$behind|$colorline\" | awk -F'|' -vOFS='|' '{$5=substr($5,1,70)}1'; done | ( echo \"ahead|behind||branch|lastcommit|message|author\\n\" && cat) | column -ts'|'; }; r"
    wp = !git wip && git push
    cleandiff = !git diff --no-ext-diff
    treeswap = "!f() { HERE=\"$(git rev-parse --show-toplevel)\"; OTHER=\"$(git worktree list --porcelain | grep '^worktree ' | sed 's/^worktree //' | grep -vx \"$HERE\" | head -1)\"; if [ -z \"$OTHER\" ]; then echo 'Error: no other worktree found'; exit 1; fi; B1=\"$(git -C \"$HERE\" symbolic-ref --short HEAD)\"; B2=\"$(git -C \"$OTHER\" symbolic-ref --short HEAD)\"; if [ \"$B1\" = \"$B2\" ]; then echo \"Both worktrees already on same branch: $B1\"; exit 1; fi; echo \"Swapping: $B1 <-> $B2\"; git -C \"$OTHER\" checkout --detach HEAD --quiet && git -C \"$HERE\" checkout \"$B2\" --quiet && git -C \"$OTHER\" checkout \"$B1\" --quiet && echo \"Done! $(basename \"$HERE\") -> $B2, $(basename \"$OTHER\") -> $B1\"; }; f"
[push]
	default = simple
[user]
    name = chrisnojima
    email = cnojima@keyba.se
    signingkey = E49ED968
[diff]
    external = difft
    tool = difftastic
[difftool]
    prompt = false
[difftool "difftastic"]
    cmd = difft "$LOCAL" "$REMOTE"
[core]
	editor = /Users/chrisnojima/.local/bin/lvim
    ; pager = diff-so-fancy | less -r
[pager]
        difftool = true
[merge]
    ff = only
[filter "lfs"]
	clean = git-lfs clean %f
	smudge = git-lfs smudge %f
	required = true
[transfer]
    fsckobjects = true
[fetch]
    fsckobjects = true
[receive]
    fsckObjects = true
[commit]
    gpgsign = true
[color]
	ui = always
[color "diff"]
	meta = yellow bold
	commit = green bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = "red bold 52"
	newNormal = "green bold"
	newHighlight = "green bold 22"
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[branch]
	sort = -committerdate
[column]
	ui = auto
